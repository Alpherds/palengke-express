{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "order_code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "customer_name": {
      "type": "string",
      "required": true
    },
    "contact_number": {
      "type": "string",
      "required": true
    },
    "quantity": {
      "type": "integer",
      "required": true,
      "default": 1,
      "min": 1
    },
    "total_amount": {
      "type": "decimal",
      "required": true,
      "default": 0,
      "min": 0
    },
    "order_status": {
      "type": "enumeration",
      "required": true,
      "default": "pending",
      "enum": [
        "pending",
        "confirmed",
        "completed",
        "cancelled"
      ]
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "orders"
    }
  }
}
